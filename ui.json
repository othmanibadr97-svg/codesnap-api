    "image": "https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?w=400&h=800&fit=crop",
    "type": "ecommerce",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0b0e14;font-family:'Inter',sans-serif;display:flex;align-items:center;justify-content:center;padding:20px}.cart-item{max-width:380px;width:100%;background:#111827;border-radius:28px;padding:20px;display:flex;gap:16px;border:1px solid #1f2937;transition:0.2s}.cart-item:hover{transform:translateX(5px)}.product-img{width:80px;height:80px;background:linear-gradient(135deg,#3b82f6,#8b5cf6);border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:32px}.details{flex:1}.product-title{font-weight:700;color:#fff;margin-bottom:4px}.product-price{color:#3b82f6;font-weight:700}.quantity{display:flex;align-items:center;gap:12px;margin-top:12px}.qty-btn{width:28px;height:28px;background:#1f2937;border:none;border-radius:8px;color:#fff;cursor:pointer;font-weight:700}.qty-num{color:#fff;font-weight:600}</style></head><body><div class=\"cart-item\"><div class=\"product-img\">👟</div><div class=\"details\"><div class=\"product-title\">Nike Air Max</div><div class=\"product-price\">$129.99</div><div class=\"quantity\"><button class=\"qty-btn\">-</button><span class=\"qty-num\">1</span><button class=\"qty-btn\">+</button></div></div></div><script>let qty=1;const numSpan=document.querySelector('.qty-num');document.querySelectorAll('.qty-btn').forEach(btn=>{btn.addEventListener('click',()=>{if(btn.innerText==='+'&&qty<10)qty++;else if(btn.innerText==='-'&&qty>1)qty--;numSpan.innerText=qty;alert(`Quantity: ${qty}`)})});</script></body></html>"
  },
  {
    "title": "Pulse Button Effect",
    "image": "https://images.unsplash.com/photo-1611162616305-c69b3fa7fbe0?w=400&h=800&fit=crop",
    "type": "button",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0a0a;font-family:'Poppins',sans-serif;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:30px;padding:20px}.pulse-btn{position:relative;padding:14px 36px;font-size:18px;font-weight:600;border:none;border-radius:50px;background:#ff4757;color:#fff;cursor:pointer;overflow:hidden;transition:0.3s}.pulse-btn::before{content:'';position:absolute;top:50%;left:50%;width:0;height:0;border-radius:50%;background:rgba(255,255,255,0.5);transform:translate(-50%,-50%);transition:width 0.6s,height 0.6s}.pulse-btn:active::before{width:300px;height:300px;opacity:0}.ripple-btn{background:#1e90ff;padding:14px 36px;border:none;border-radius:50px;font-weight:600;color:#fff;cursor:pointer;transition:0.2s}.ripple-btn:hover{transform:scale(1.05);box-shadow:0 5px 20px rgba(30,144,255,0.4)}.glow-btn{background:linear-gradient(90deg,#00d2ff,#3a7bd5);padding:14px 36px;border:none;border-radius:50px;font-weight:600;color:#fff;cursor:pointer;animation:glow 2s infinite}@keyframes glow{0%{box-shadow:0 0 5px #00d2ff}50%{box-shadow:0 0 20px #3a7bd5}100%{box-shadow:0 0 5px #00d2ff}}</style></head><body><button class=\"pulse-btn\">Pulse Effect</button><button class=\"ripple-btn\">Ripple Hover</button><button class=\"glow-btn\">Neon Glow</button><script>document.querySelectorAll('button').forEach(btn=>{btn.addEventListener('click',()=>alert(`Button: ${btn.innerText} clicked`))});</script></body></html>"
  },
  {
    "title": "Feature Cards Grid",
    "image": "https://images.unsplash.com/photo-1557821552-17105176677c?w=400&h=800&fit=crop",
    "type": "card",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:radial-gradient(circle at 10% 20%,#1e1e2f,#0a0a0f);font-family:'Inter',sans-serif;padding:20px}.cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px;max-width:900px;margin:0 auto}.card{background:rgba(30,30,45,0.6);backdrop-filter:blur(12px);border-radius:28px;padding:24px;border:1px solid rgba(255,255,255,0.1);transition:all 0.3s}.card:hover{transform:translateY(-8px);background:rgba(30,30,45,0.8)}.icon{font-size:42px;margin-bottom:16px}.card h3{color:#fff;margin-bottom:8px}.card p{color:#94a3b8;font-size:14px;line-height:1.5}</style></head><body><div class=\"cards-grid\"><div class=\"card\"><div class=\"icon\">⚡</div><h3>Lightning Fast</h3><p>Optimized performance with instant loading</p></div><div class=\"card\"><div class=\"icon\">🔒</div><h3>Secure</h3><p>Enterprise-grade security protocols</p></div><div class=\"card\"><div class=\"icon\">🎨</div><h3>Customizable</h3><p>Flexible theming and components</p></div><div class=\"card\"><div class=\"icon\">📱</div><h3>Responsive</h3><p>Works perfectly on all devices</p></div></div><script>document.querySelectorAll('.card').forEach(card=>{card.addEventListener('click',()=>alert(`Feature: ${card.querySelector('h3').innerText}`))});</script></body></html>"
