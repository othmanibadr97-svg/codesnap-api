lder=\"🔒 Password\" required></div><button type=\"submit\" class=\"login-btn\">Login →</button><div class=\"links\"><a href=\"#\">Forgot Password?</a><a href=\"#\">Sign Up</a></div><div id=\"errorMsg\" class=\"error\"></div></form></div></div><script>document.getElementById('loginForm').addEventListener('submit',function(e){e.preventDefault();let email=document.getElementById('email').value;let pwd=document.getElementById('password').value;let errorDiv=document.getElementById('errorMsg');if(!email||!pwd){errorDiv.style.display='block';errorDiv.textContent='❌ All fields are required!';setTimeout(()=>{errorDiv.style.display='none';},2000);}else if(!email.includes('@')){errorDiv.style.display='block';errorDiv.textContent='❌ Invalid email format!';setTimeout(()=>{errorDiv.style.display='none';},2000);}else{errorDiv.style.display='block';errorDiv.style.color='#00ff9d';errorDiv.textContent='✅ Login successful! Redirecting...';setTimeout(()=>{alert('Welcome to CodeSnap!');},1500);}});</script></body></html>"
