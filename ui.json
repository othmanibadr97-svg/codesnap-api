    "type": "signin",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0a0a;font-family:'Space Grotesk',sans-serif;display:flex;align-items:center;justify-content:center;padding:20px;background-image:radial-gradient(circle at 25% 40%,rgba(80,70,200,0.15) 0%,rgba(0,0,0,0) 50%)}.signin-box{background:#111;border-radius:48px;padding:48px 32px;width:100%;max-width:400px;border:1px solid #222;box-shadow:0 20px 40px rgba(0,0,0,0.5)}.logo{font-size:42px;font-weight:700;background:linear-gradient(135deg,#fff,#9b59b6);-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:12px}h3{color:#fff;font-size:24px;margin-bottom:8px}.greeting{color:#666;margin-bottom:32px;font-size:14px}.input-wrapper{margin-bottom:24px}.input-wrapper input{width:100%;padding:16px 18px;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:28px;font-size:15px;color:#fff;font-family:'Space Grotesk',sans-serif;transition:all 0.2s}.input-wrapper input:focus{outline:none;border-color:#9b59b6;background:#1e1e1e}.input-wrapper label{display:block;color:#888;font-size:12px;margin-bottom:8px;font-weight:500}.signin-btn{width:100%;padding:16px;background:#9b59b6;border:none;border-radius:32px;font-size:16px;font-weight:600;color:#fff;cursor:pointer;transition:all 0.2s;margin-top:8px}.signin-btn:hover{background:#8e44ad;transform:scale(0.98)}.forgot-link{display:block;text-align:center;margin-top:20px;color:#666;text-decoration:none;font-size:13px;transition:color 0.2s}.forgot-link:hover{color:#9b59b6}</style></head><body><div class=\"signin-box\"><div class=\"logo\">◆ CodeSnap</div><h3>Welcome back</h3><p class=\"greeting\">Sign in to your workspace</p><div class=\"input-wrapper\"><label>EMAIL</label><input type=\"email\" placeholder=\"hello@codesnap.dev\"></div><div class=\"input-wrapper\"><label>PASSWORD</label><input type=\"password\" placeholder=\"········\"></div><button class=\"signin-btn\">Sign in →</button><a href=\"#\" class=\"forgot-link\">Forgot password?</a></div><script>document.querySelector('.signin-btn').addEventListener('click',()=>alert('Sign in demo'));</script></body></html>"
