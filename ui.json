  {
    "title": "Task Dashboard",
    "image": "https://images.unsplash.com/photo-1557804506-669a67965ba0?w=400&h=800&fit=crop",
    "type": "dashboard",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{background:#0a0c10;font-family:'Inter',sans-serif;padding:20px;color:#eef2ff}.app{max-width:450px;margin:0 auto}.header{display:flex;justify-content:space-between;margin-bottom:24px}.greeting h1{font-size:22px}.badge{background:#1f2937;padding:8px 16px;border-radius:30px;font-size:13px}.stats{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px}.stat{background:#111827;border-radius:20px;padding:16px;border:1px solid #1f2937}.stat h4{font-size:12px;color:#9ca3af}.stat p{font-size:24px;font-weight:700;margin-top:6px}.tasks{background:#111827;border-radius:24px;padding:16px;border:1px solid #1f2937}.tasks h3{margin-bottom:16px}.task-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid #1f2937}.task-check{width:20px;height:20px;border:2px solid #4b5563;border-radius:6px;background:transparent;cursor:pointer}.task-text{flex:1}.task-time{font-size:11px;color:#6b7280}</style></head><body><div class=\"app\"><div class=\"header\"><div class=\"greeting\"><h1>Hello, Alex</h1><p style=\"font-size:12px;color:#6b7280\">Today's tasks</p></div><div class=\"badge\">Feb 20</div></div><div class=\"stats\"><div class=\"stat\"><h4>Pending</h4><p>8</p></div><div class=\"stat\"><h4>Completed</h4><p>12</p></div></div><div class=\"tasks\"><h3>My Tasks</h3><div class=\"task-item\"><div class=\"task-check\"></div><div class=\"task-text\">Review pull requests</div><div class=\"task-time\">10:00 AM</div></div><div class=\"task-item\"><div class=\"task-check\"></div><div class=\"task-text\">Update documentation</div><div class=\"task-time\">2:00 PM</div></div><div class=\"task-item\"><div class=\"task-check\"></div><div class=\"task-text\">Team meeting</div><div class=\"task-time\">4:30 PM</div></div></div></div><script>document.querySelectorAll('.task-check').forEach(check=>{check.addEventListener('click',function(){this.style.background=this.style.background==='rgb(59,130,246)'?'transparent':'#3b82f6'})});</script></body></html>"
