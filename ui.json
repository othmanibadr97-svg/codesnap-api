    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#121212;font-family:'Manrope',sans-serif;display:flex;align-items:center;justify-content:center;padding:20px}.product-card{max-width:340px;width:100%;background:#1e1e2a;border-radius:32px;overflow:hidden;transition:transform 0.3s,box-shadow 0.3s}.product-card:hover{transform:translateY(-8px);box-shadow:0 20px 35px -10px rgba(0,0,0,0.5)}.product-image{height:220px;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;font-size:64px}.product-info{padding:24px}.product-title{font-size:20px;font-weight:800;color:#fff;margin-bottom:8px}.product-category{color:#94a3b8;font-size:12px;margin-bottom:16px}.price-row{display:flex;align-items:baseline;gap:12px;margin-bottom:20px}.current-price{font-size:28px;font-weight:800;color:#38bdf8}.old-price{font-size:14px;color:#64748b;text-decoration:line-through}.rating{display:flex;gap:4px;margin-bottom:20px;color:#fbbf24}.add-btn{width:100%;padding:14px;background:linear-gradient(90deg,#38bdf8,#3b82f6);border:none;border-radius:40px;font-size:15px;font-weight:700;color:#fff;cursor:pointer;transition:transform 0.2s}.add-btn:hover{transform:scale(0.98)}</style></head><body><div class=\"product-card\"><div class=\"product-image\">🎧</div><div class=\"product-info\"><div class=\"product-title\">Wireless Headphones</div><div class=\"product-category\">Audio • Electronics</div><div class=\"price-row\"><span class=\"current-price\">$89.99</span><span class=\"old-price\">$129.99</span></div><div class=\"rating\">★★★★☆ 4.5</div><button class=\"add-btn\">Add to Cart →</button></div></div><script>document.querySelector('.add-btn').addEventListener('click',()=>alert('Item added to cart'));</script></body></html>"
