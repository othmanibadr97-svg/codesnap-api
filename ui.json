    "image": "https://images.unsplash.com/photo-1549692520-acc6669e2f0c?w=400&h=800&fit=crop",
    "type": "profile",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0d1117;font-family:'JetBrains Mono',monospace;display:flex;align-items:center;justify-content:center;padding:20px}.profile{max-width:360px;width:100%;background:#161b22;border-radius:32px;padding:32px 24px;border:1px solid #30363d;text-align:center}.avatar{width:100px;height:100px;background:linear-gradient(135deg,#58a6ff,#1f6feb);border-radius:50%;margin:0 auto 20px;display:flex;align-items:center;justify-content:center;font-size:40px}.name{font-size:24px;font-weight:700;color:#c9d1d9}.handle{color:#8b949e;font-size:13px;margin:8px 0 16px}.stats{display:flex;justify-content:center;gap:32px;margin:24px 0;padding:16px 0;border-top:1px solid #30363d;border-bottom:1px solid #30363d}.stat-value{font-weight:700;color:#58a6ff}.stat-label{font-size:11px;color:#8b949e}.follow-btn{width:100%;padding:12px;background:#238636;border:none;border-radius:24px;color:#fff;font-weight:600;font-family:inherit;cursor:pointer;transition:0.2s}.follow-btn:hover{background:#2ea043}</style></head><body><div class=\"profile\"><div class=\"avatar\">🐙</div><div class=\"name\">Sarah Chen</div><div class=\"handle\">@sarahcodes</div><div class=\"stats\"><div><div class=\"stat-value\">127</div><div class=\"stat-label\">repos</div></div><div><div class=\"stat-value\">2.3k</div><div class=\"stat-label\">followers</div></div><div><div class=\"stat-value\">89</div><div class=\"stat-label\">following</div></div></div><button class=\"follow-btn\">Follow</button></div><script>document.querySelector('.follow-btn').addEventListener('click',function(){this.innerText=this.innerText==='Follow'?'Following':'Follow';alert('Profile action demo')});</script></body></html>"
