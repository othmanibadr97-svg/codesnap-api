  {
    "title": "Analytics Dashboard",
    "image": "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=400&h=800&fit=crop",
    "type": "dashboard",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{background:#0b1120;font-family:'Inter',sans-serif;padding:20px;color:#e2e8f0}.dashboard{max-width:480px;margin:0 auto}.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;padding:0 8px}.greeting h2{font-size:20px;font-weight:600}.greeting p{font-size:13px;color:#64748b}.avatar{width:44px;height:44px;background:linear-gradient(135deg,#3b82f6,#8b5cf6);border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700}.stats-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:28px}.stat-card{background:rgba(30,41,59,0.6);backdrop-filter:blur(10px);border-radius:24px;padding:16px;border:1px solid rgba(255,255,255,0.05)}.stat-value{font-size:28px;font-weight:800;margin-top:8px}.stat-label{font-size:12px;color:#94a3b8}.section-title{font-size:18px;font-weight:600;margin-bottom:16px;margin-top:8px}.recent-list{background:rgba(30,41,59,0.4);border-radius:24px;padding:8px;border:1px solid rgba(255,255,255,0.05)}.recent-item{display:flex;align-items:center;padding:14px;border-bottom:1px solid rgba(255,255,255,0.05)}.recent-item:last-child{border-bottom:none}.item-icon{width:40px;height:40px;background:rgba(59,130,246,0.2);border-radius:20px;display:flex;align-items:center;justify-content:center;margin-right:14px}.item-info{flex:1}.item-title{font-weight:500;margin-bottom:4px}.item-date{font-size:11px;color:#64748b}.item-value{font-weight:700;color:#3b82f6}</style></head><body><div class=\"dashboard\"><div class=\"header\"><div class=\"greeting\"><h2>Hello, Alex</h2><p>Welcome back</p></div><div class=\"avatar\">A</div></div><div class=\"stats-grid\"><div class=\"stat-card\"><div class=\"stat-label\">Projects</div><div class=\"stat-value\">12</div></div><div class=\"stat-card\"><div class=\"stat-label\">Tasks</div><div class=\"stat-value\">48</div></div><div class=\"stat-card\"><div class=\"stat-label\">Hours</div><div class=\"stat-value\">127</div></div><div class=\"stat-card\"><div class=\"stat-label\">Progress</div><div class=\"stat-value\">76%</div></div></div><div class=\"section-title\">Recent Activity</div><div class=\"recent-list\"><div class=\"recent-item\"><div class=\"item-icon\">📁</div><div class=\"item-info\"><div class=\"item-title\">Updated UI Kit</div><div class=\"item-date\">2 hours ago</div></div><div class=\"item-value\">+12</div></div><div class=\"recent-item\"><div class=\"item-icon\">💬</div><div class=\"item-info\"><div class=\"item-title\">Team Meeting</div><div class=\"item-date\">Yesterday</div></div><div class=\"item-value\">✅</div></div><div class=\"recent-item\"><div class=\"item-icon\">🎨</div><div class=\"item-info\"><div class=\"item-title\">Design Review</div><div class=\"item-date\">Yesterday</div></div><div class=\"item-value\">📝</div></div></div></div><script>console.log('Dashboard ready');</script></body></html>"
