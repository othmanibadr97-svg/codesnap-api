orm id=\"loginForm\"><div class=\"input-field\"><input type=\"email\" id=\"email\" required><label>Email Address</label></div><div class=\"input-field\"><input type=\"password\" id=\"password\" required><label>Password</label></div><button type=\"submit\" class=\"login-button\">Login</button><div class=\"options\"><a href=\"#\">Forgot password?</a><a href=\"#\">Create account</a></div></form></div><script>document.getElementById('loginForm').addEventListener('submit',function(e){e.preventDefault();let email=document.getElementById('email').value;let pwd=document.getElementById('password').value;if(email&&pwd&&email.includes('@')){alert('Welcome back to CodeSnap!');}else{alert('Please fill all fields correctly!');}});</script></body></html>"
