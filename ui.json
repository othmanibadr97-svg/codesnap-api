    "title": "Modern Signup Flow",
    "image": "https://images.unsplash.com/photo-1633114128174-2f8aa49759b0?w=400&h=800&fit=crop",
    "type": "signup",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:radial-gradient(circle at 10% 20%,#1e1b4b,#0b081a);font-family:'Outfit',sans-serif;display:flex;align-items:center;justify-content:center;padding:20px}.container{max-width:400px;width:100%}.card{background:rgba(15,25,45,0.7);backdrop-filter:blur(16px);border-radius:40px;padding:36px 28px;border:1px solid rgba(255,255,255,0.1);box-shadow:0 20px 40px rgba(0,0,0,0.4)}h1{font-size:36px;font-weight:800;background:linear-gradient(120deg,#fff,#a78bfa);-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:8px}.sub{color:#94a3b8;margin-bottom:32px;font-size:14px}.input-field{margin-bottom:20px}.input-field input{width:100%;padding:15px 18px;background:rgba(255,255,255,0.03);border:1.5px solid rgba(255,255,255,0.1);border-radius:28px;font-size:15px;color:#fff;font-family:'Outfit',sans-serif;transition:all 0.3s}.input-field input:focus{outline:none;border-color:#a78bfa;background:rgba(255,255,255,0.08);box-shadow:0 0 0 4px rgba(167,139,250,0.1)}.input-field input::placeholder{color:#475569}.signup-btn{width:100%;padding:15px;background:linear-gradient(90deg,#8b5cf6,#6d28d9);border:none;border-radius:32px;font-size:16px;font-weight:700;color:#fff;cursor:pointer;transition:all 0.3s;margin-top:12px}.signup-btn:hover{transform:translateY(-2px);box-shadow:0 10px 25px -5px rgba(139,92,246,0.4)}.terms{text-align:center;margin-top:24px;font-size:12px;color:#64748b}.terms a{color:#a78bfa;text-decoration:none}.divider{display:flex;align-items:center;margin:24px 0;gap:12px}.divider-line{flex:1;height:1px;background:rgba(255,255,255,0.1)}.divider-text{color:#64748b;font-size:12px}.social-icons{display:flex;gap:16px;justify-content:center}.social-icon{width:48px;height:48px;background:rgba(255,255,255,0.05);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all 0.2s;border:1px solid rgba(255,255,255,0.1)}.social-icon:hover{background:rgba(255,255,255,0.15);transform:scale(1.05)}.login-link{text-align:center;margin-top:28px;color:#94a3b8}.login-link a{color:#a78bfa;font-weight:600;text-decoration:none}</style></head><body><div class=\"container\"><div class=\"card\"><h1>Join us</h1><p class=\"sub\">Create your account</p><div class=\"input-field\"><input type=\"text\" placeholder=\"Full name\"></div><div class=\"input-field\"><input type=\"email\" placeholder=\"Email address\"></div><div class=\"input-field\"><input type=\"password\" placeholder=\"Password\"></div><div class=\"input-field\"><input type=\"password\" placeholder=\"Confirm password\"></div><button class=\"signup-btn\">Create account →</button><div class=\"divider\"><div class=\"divider-line\"></div><div class=\"divider-text\">OR</div><div class=\"divider-line\"></div></div><div class=\"social-icons\"><div class=\"social-icon\">G</div><div class=\"social-icon\">f</div><div class=\"social-icon\">in</div></div><div class=\"terms\">By signing up, you agree to our <a href=\"#\">Terms</a> & <a href=\"#\">Privacy</a></div><div class=\"login-link\">Already have an account? <a href=\"#\">Sign in</a></div></div></div><script>document.querySelector('.signup-btn').addEventListener('click',()=>alert('Account created! (Demo)'));</script></body></html>"
