  {
    "title": "Splash with Animation",
    "image": "https://images.unsplash.com/photo-1611162618071-b39a2ec055fb?w=400&h=800&fit=crop",
    "type": "splash",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);display:flex;align-items:center;justify-content:center;font-family:'Segoe UI',system-ui}.splash{text-align:center;animation:zoomIn 0.6s ease}.logo{font-size:72px;margin-bottom:20px;animation:rotateScale 1s infinite alternate}@keyframes rotateScale{from{transform:scale(0.8) rotate(0deg)}to{transform:scale(1.2) rotate(10deg)}}@keyframes zoomIn{from{opacity:0;transform:scale(0.5)}to{opacity:1;transform:scale(1)}}.app-title{font-size:42px;font-weight:800;color:#fff;letter-spacing:-1px}.loader{width:48px;height:48px;border:4px solid rgba(255,255,255,0.3);border-top-color:#fff;border-radius:50%;animation:spin 1s linear infinite;margin:40px auto 0}@keyframes spin{to{transform:rotate(360deg)}}</style></head><body><div class=\"splash\"><div class=\"logo\">📸</div><div class=\"app-title\">CodeSnap</div><div class=\"loader\"></div></div><script>setTimeout(()=>alert('App ready'),2500);</script></body></html>"
