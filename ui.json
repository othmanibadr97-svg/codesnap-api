    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:linear-gradient(145deg,#0f172a,#1e1b4b);font-family:'DM Sans',sans-serif;display:flex;align-items:center;justify-content:center;padding:20px}.card-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;max-width:1000px;width:100%}.card{background:rgba(255,255,255,0.05);backdrop-filter:blur(16px);border-radius:28px;padding:24px;border:1px solid rgba(255,255,255,0.15);transition:all 0.3s}.card:hover{transform:translateY(-6px);background:rgba(255,255,255,0.08)}.card-icon{font-size:44px;margin-bottom:20px}.card-title{font-size:20px;font-weight:700;color:#fff;margin-bottom:12px}.card-desc{color:#cbd5e1;font-size:14px;line-height:1.5;margin-bottom:20px}.card-link{color:#38bdf8;text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:6px;transition:gap 0.2s}.card-link:hover{gap:10px}</style></head><body><div class=\"card-grid\"><div class=\"card\"><div class=\"card-icon\">🚀</div><div class=\"card-title\">Quick Start</div><div class=\"card-desc\">Get started with our pre-built templates and components.</div><a href=\"#\" class=\"card-link\">Learn more →</a></div><div class=\"card\"><div class=\"card-icon\">🎨</div><div class=\"card-title\">Modern Design</div><div class=\"card-desc\">Beautiful UI components with glassmorphism effects.</div><a href=\"#\" class=\"card-link\">Explore →</a></div><div class=\"card\"><div class=\"card-icon\">⚡</div><div class=\"card-title\">Performance</div><div class=\"card-desc\">Optimized for mobile devices with smooth animations.</div><a href=\"#\" class=\"card-link\">Read more →</a></div></div><script>document.querySelectorAll('.card-link').forEach(link=>{link.addEventListener('click',(e)=>{e.preventDefault();alert(`Card clicked: ${link.innerText}`)})});</script></body></html>"
