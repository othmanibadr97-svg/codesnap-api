    "image": "https://images.unsplash.com/photo-1563986768609-322da13575f3?w=400&h=800&fit=crop",
    "type": "button",
    "code": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\"><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0f1e;font-family:'Inter',sans-serif;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:40px;padding:20px}.btn{position:relative;padding:14px 32px;font-size:16px;font-weight:600;border:none;border-radius:60px;cursor:pointer;transition:all 0.3s ease;overflow:hidden;z-index:1}.btn-primary{background:linear-gradient(90deg,#ff6a88,#f02fc2);color:#fff;box-shadow:0 4px 15px rgba(240,47,194,0.3)}.btn-primary:hover{transform:translateY(-3px);box-shadow:0 8px 25px rgba(240,47,194,0.4)}.btn-outline{background:transparent;border:2px solid #38bdf8;color:#38bdf8}.btn-outline:hover{background:#38bdf8;color:#fff;transform:scale(1.05)}.btn-glass{background:rgba(255,255,255,0.1);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.2);color:#fff}.btn-glass:hover{background:rgba(255,255,255,0.2);letter-spacing:1px}.btn-neon{background:#111;color:#0f0;border:1px solid #0f0;box-shadow:0 0 10px rgba(0,255,0,0.3)}.btn-neon:hover{box-shadow:0 0 20px rgba(0,255,0,0.6);text-shadow:0 0 5px #0f0}.btn-block{width:100%;max-width:280px;padding:16px;background:linear-gradient(90deg,#8b5cf6,#ec4899);color:#fff}.btn-block:hover{transform:translateY(-2px)}.button-group{display:flex;gap:20px;flex-wrap:wrap;justify-content:center}</style></head><body><div class=\"button-group\"><button class=\"btn btn-primary\">Primary Action</button><button class=\"btn btn-outline\">Outline Button</button><button class=\"btn btn-glass\">Glassmorphism</button><button class=\"btn btn-neon\">Neon Effect</button><button class=\"btn btn-block\">Full Width</button></div><script>document.querySelectorAll('.btn').forEach(btn=>{btn.addEventListener('click',()=>alert(`Button clicked: ${btn.innerText}`))});</script></body></html>"
